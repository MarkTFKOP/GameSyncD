# Copy to env.sh and fill values.
# This file is safe to commit.

export STEAM_API_KEY=""
export STEAM_ID=""

# Raw Cookie header string from a logged-in GOG request.
export GOG_COOKIE=""

# Output folder for generated JSON files.
export OUTPUT_DIR="data"

# Local Node server port.
export BACKEND_PORT="8787"

# Vite frontend port.
export FRONTEND_PORT="5173"

# API base consumed by frontend.
export VITE_API_BASE="http://localhost:8787"

# Optional: explicit path to legendary binary (if not in PATH).
# export LEGENDARY_BIN="/absolute/path/to/legendary"
